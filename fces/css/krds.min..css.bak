  }
}

.form-group [class^="form-hint"]::before {
  display: inline-flex;
  content: "";
  display: inline-flex;
  width: var(--krds-icon--size-small);
  height: var(--krds-icon--size-small);
  background-color: var(--krds-light-color-text-basic);
